# Shopify
# Your store URL (e.g., your-store.myshopify.com — no https://)
VITE_SHOPIFY_STORE_URL=your-store.myshopify.com

# Shopify Admin API token
# Go to: Shopify Admin → Settings → Apps and sales channels → Develop apps
# Create an app, enable Admin API, grant read_orders scope, install, copy token
VITE_SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Meta (Facebook) Ads
# Go to: developers.facebook.com → My Apps → your app → Tools → Graph API Explorer
# Generate a long-lived token with ads_read permission
VITE_META_ACCESS_TOKEN=EAAxxxxxxxxxx

# Your Meta Ad Account ID (e.g., act_123456789)
# Found in: Meta Business Manager → Ad Accounts
VITE_META_AD_ACCOUNT_ID=act_xxxxxxxxxx

# Anthropic Claude API key
# Go to: console.anthropic.com → API Keys → Create key
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
